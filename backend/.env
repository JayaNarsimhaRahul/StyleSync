NODE_ENV=development
PORT=5000

# MongoDB (Local fallback, change to MongoDB Atlas URI if needed)
MONGO_URI=mongodb://localhost:27017/stylesync

# JWT Keys (Change these secrets in production)
JWT_ACCESS_SECRET=stylesync_access_token_super_secret_key_12345
JWT_REFRESH_SECRET=stylesync_refresh_token_super_secret_key_67890
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cloudinary (Leave blank to use local placeholders)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (Bypassed by payment simulator)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (Bypassed by terminal email logger)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# CORS
CLIENT_URL=http://localhost:5173
